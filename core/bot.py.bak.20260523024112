    acc.logout_dev(update.effective_user.id)
    await update.message.reply_text(
        "🔓 Sesión developer cerrada. Ahora estás en modo <b>técnico de soporte</b>.\n"
        "<i>Escribe cualquier saludo para ver el panel técnico.</i>",
        parse_mode=PM,
    )


# ── Lenguaje natural ──────────────────────────────────────────────────────────

async def msg_natural(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    level = await _guard(update)
    if not level:
        return

    text    = update.message.text or ""
    user_id = update.effective_user.id

    if acc.technician_only_mode():
        acc.clear_pending_dev_auth(user_id)

    # Rate-limit siempre, incluso cuando el bot está pausado
    if not acc.is_pending_auth(user_id) and not _mnt.check_user_rate(user_id):
        await update.message.reply_text("⏳ Vas muy rápido — espera unos segundos.")
        return

    # Modo mantenimiento global (solo bloquea texto libre, no comandos)
    if _mnt.is_paused() and level != "developer":
        await update.message.reply_text(
            "🛠️ <b>Asistente en pausa</b> — cuota Groq en enfriamiento.\n"
            "<i>Usa /salud · /alertas mientras tanto.</i>",
            parse_mode=PM,
        )
        return

    # Flujo contraseña developer
    if acc.is_pending_auth(user_id):
        if acc.verify_dev_password(user_id, text):
            await update.message.reply_text(
                "✅ <b>Contraseña correcta.</b> Sesión developer activada.", parse_mode=PM
            )
            await _send_start(update.message, "developer")
        else:
            await update.message.reply_text(
                "❌ Contraseña incorrecta. Accediendo como <b>técnico de soporte</b>.", parse_mode=PM
            )
            await _send_start(update.message, "tecnico")
        return

    # Saludos → respuesta corta sin Groq
    if _is_greeting(text):
        resp = random.choice(_GREETING_RESPONSES).format(site=fmt.e(SITE_NAME))
        await update.message.reply_text(resp, parse_mode=PM)
        return

    # Lenguaje natural con tool calling y memoria
    await _typing(update, ctx)
    _memory.add_message(user_id, "user", text, level)
    history = _memory.get_history(user_id)

    loop = asyncio.get_running_loop()
    try:
        respuesta = await asyncio.wait_for(
            loop.run_in_executor(None, partial(_groq_chat, history, level=level)),
            timeout=25.0,
        )
    except asyncio.TimeoutError:
        respuesta = "⏱ La consulta tardó demasiado. Intenta de nuevo con una pregunta más concreta."
    except Exception as ex:
        log.warning("Groq ejecutor: %s", ex)
        respuesta = "⚠️ No pude contactar el asistente. Usa /salud · /ayuda."

    respuesta = (respuesta or "").strip() or \
        "Sin respuesta del asistente. Usa /salud para datos del servidor."

    _memory.add_message(user_id, "assistant", respuesta, level)
    # Groq genera Markdown — enviarlo con parse_mode Markdown
    await update.message.reply_text(respuesta[:4096], parse_mode="Markdown")


# ── Foto → logo (solo developer) ──────────────────────────────────────────────

async def msg_photo(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    level = await _guard(update)
    if not level:
        return
    if acc.technician_only_mode() or level != "developer":
        await update.message.reply_text(
            "El cambio de logo lo gestiona <b>soporte USB</b>.", parse_mode=PM
        )
        return
    if not update.message.photo:
        await update.message.reply_text("Envía una imagen JPG.")
        return
    try:
        photo = update.message.photo[-1]
        file  = await ctx.bot.get_file(photo.file_id)
        await file.download_to_drive(LOGO_PATH)
        await update.message.reply_text("✅ Logo actualizado. Usa /start para verlo.", parse_mode=PM)
    except Exception as ex:
        await update.message.reply_text(
            f"❌ Error descargando imagen: {fmt.e(str(ex))}", parse_mode=PM
        )


