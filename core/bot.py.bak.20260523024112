# ── /historial ────────────────────────────────────────────────────────────────

async def cmd_historial(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    level = await _guard(update)
    if not level:
        return
    rows = changelog.get_recent(10)
    if not rows:
        await update.message.reply_text("📋 No hay cambios registrados aún.")
        return

    lines = []
    for r in rows:
        cid, ts, ulevel, action, target, details, reverted = r
        estado = " ↩️ revertido" if reverted else ""
        lines.append(
            f"  <code>#{cid}</code> [{fmt.e(ts[5:16])}] <b>{fmt.e(action)}</b> "
            f"<code>{fmt.e(target)}</code> ({fmt.e(ulevel)}){fmt.e(estado)}"
        )
        if details and details != "None":
            lines.append(f"     <i>{fmt.e(details[:60])}</i>")

    if level == "developer":
        lines.append("\n<i>Usa /revertir &lt;id&gt; para deshacer un cambio reversible.</i>")

    await update.message.reply_text(
        fmt.card("📜", f"Cambios recientes — {SITE_NAME}", lines), parse_mode=PM
    )


# ── /revertir ─────────────────────────────────────────────────────────────────

async def cmd_revertir(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    level = await _guard(update)
    if not level:
        return
    if not ctx.args or not ctx.args[0].isdigit():
        await update.message.reply_text(
            "Uso: /revertir <code>&lt;id&gt;</code>\nObtén el ID con /historial.",
            parse_mode=PM,
        )
        return
    change_id = int(ctx.args[0])

    if level == "tecnico":
        row = changelog.get_change_full(change_id)
        if not row:
            await update.message.reply_text("❌ Cambio no encontrado.")
            return
        _, _, action, target, _, _, owner_id = row
        if str(update.effective_user.id) != str(owner_id):
            await update.message.reply_text("⛔ Solo puedes revertir tus propios cambios.")
            return
        if action not in ("block", "unblock"):
            await update.message.reply_text(
                "⛔ Como técnico solo puedes revertir bloqueos y desbloqueos.\n"
                "<i>Contacta al developer para otros cambios.</i>",
                parse_mode=PM,
            )
            return

    await update.message.reply_text(f"⏳ Revirtiendo cambio #{change_id}...")
    ok, msg = changelog.revert(change_id)
    icon    = "✅" if ok else "❌"
    await update.message.reply_text(f"{icon} #{change_id}: {fmt.e(msg)}", parse_mode=PM)


