# ── /diagnostico ──────────────────────────────────────────────────────────────

async def cmd_diagnostico(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    level = await _guard(update)
    if not level:
        return
    if not ctx.args:
        await update.message.reply_text(
            f"Uso: /diagnostico <code>192.168.1.1</code>", parse_mode=PM
        )
        return
    ip = ctx.args[0]
    await _typing(update, ctx)

    lines = []

    # Ping
    ping = dm.ping_device(ip)
    icon = "✅" if ping["ok"] else "🔴"
    lines.append(f"  {icon} <b>Ping:</b> {fmt.e(ping['message'])}")

    # Estado Guardian
    nodes = shomer_api.get_guardian_nodes()
    node  = next((n for n in (nodes or []) if n.get("ip") == ip or n.get("ip_address") == ip), None)
    if node:
        st     = node.get("status", "?")
        nombre = node.get("name", ip)
        st_i   = fmt.status_icon(st)
        lines.append(f"  {st_i} <b>Guardian:</b> {fmt.e(nombre)} — <code>{fmt.e(st)}</code>")
        if node.get("latency_ms"):
            lines.append(f"     Latencia: <code>{fmt.e(node['latency_ms'])} ms</code>")
    else:
        lines.append("  ⚪ <b>Guardian:</b> nodo no registrado")

    # Fallos y último reboot
    data = shomer_api.get_node_failures(ip)
    if data:
        fails = data.get("failures", 0)
        ago   = data.get("last_reboot_ago")
        f_i   = "✅" if fails == 0 else ("⚠️" if fails < 3 else "🔴")
        lines.append(f"  {f_i} <b>Fallos acumulados:</b> {fmt.e(fails)}")
        if ago is not None:
            h, m = divmod(ago // 60, 60)
            lines.append(f"     Último reboot: hace <code>{h}h {m}m</code>")
        elif node:
            lines.append("     Sin reboots registrados")

    # Uptime SNMP
    snmp_community = (node or {}).get("snmp_community", "shomer2026") or "shomer2026"
    if ping["ok"]:
        uptime = shomer_api.get_snmp_uptime(ip, snmp_community)
        if uptime:
            lines.append(f"  ⏱️ <b>Uptime SNMP:</b> <code>{fmt.e(uptime)}</code>")

    # Modo mantenimiento
    if shomer_api.get_maintenance():
        lines.append("  🔧 <b>Mantenimiento:</b> ACTIVO — reboots automáticos pausados")

    texto = fmt.card("🔍", f"Diagnóstico {ip}", lines)
    kb    = None
    if node and node.get("status") in ("offline", "no-internet") and BOT_AUTO_REBOOT:
        kb = fmt.kb([fmt.btn(f"⚡ Reiniciar {node.get('name', ip)}", f"reboot_confirm:{ip}")])

    await update.message.reply_text(texto, parse_mode=PM, reply_markup=kb)


