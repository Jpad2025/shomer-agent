            await update.message.reply_text(
                fmt.alert_card("Modo en sitio", [
                    "No hay supresiones activas.",
                    "<i>Usa /sitio &lt;ip&gt; 30m para suprimir alertas de un AP.</i>",
                ], "info"),
                parse_mode=PM,
