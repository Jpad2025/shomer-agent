# ── /start ────────────────────────────────────────────────────────────────────

async def _send_start(msg, level: str):
    fecha = datetime.now().strftime("%d/%m/%Y · %H:%M")
    rol   = "🔑 Developer" if level == "developer" else "🔵 Técnico"
    text  = (
        f"{fmt.SEP_WIDE}\n"
        f"👁️ <b>{fmt.e(SITE_NAME)}</b>\n"
        f"{fmt.SEP_WIDE}\n"
        f"<b>Shomer Sentinel 2.0</b> — herramienta de campo\n"
        f"{rol} · {fecha}\n\n"
        f"📋 /instalar — guía paso a paso\n"
        f"✔️ /verificar — check final instalación\n"
        f"🏥 /salud — servicios, disco y red\n"
        f"❓ /ayuda — todos los comandos\n\n"
        f"<i>También podés escribir en texto libre — el asistente usa datos reales del sistema.</i>"
    )
    if os.path.exists(LOGO_PATH):
        try:
            with open(LOGO_PATH, "rb") as f:
                await msg.reply_photo(photo=f, caption=text, parse_mode=PM)
            return
        except Exception:
            pass
    await msg.reply_text(text, parse_mode=PM)


async def cmd_start(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    level = await _guard(update)
    if not level:
        return

    if acc.technician_only_mode() or level == "developer":
        await _send_start(update.message, level)
