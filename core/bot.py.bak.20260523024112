        else:
            lines = []
            for ip, info in supresiones.items():
                lines.append(
                    f"  🔧 <code>{fmt.e(ip)}</code> — {fmt.e(info.get('name', ip))} "
                    f"· {fmt.e(info.get('mins_left', 0))} min restantes"
                )
