async def cmd_monitores(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    level = await _guard(update)
    if not level:
        return

    from core.monitor import get_monitor_status
    import time as _t

    LABELS = {
        "watch_hunter":           "🎯 IPs bloqueadas (Hunter)",
        "watch_devices":          "👁️ Estado equipos del agente",
        "daily_summary":          "☀️ Resumen diario 7:00 AM",
        "watch_resources":        "🖥️ CPU / RAM",
        "watch_backups":          "🛡️ Backups sin ejecutar",
        "watch_wan_outage":       "🌐 Caída WAN",
        "watch_disk":             "🖥️ Disco del servidor",
        "watch_pipeline":         "🎯 Pipeline Suricata",
        "watch_services":         "🖥️ Servicios del sistema",
        "watch_guardian_nodes":   "👁️ Estado nodos Guardian",
        "preventive_reboot":      "👁️ Reboot preventivo 4:00 AM",
        "weekly_backup":          "🛡️ Backup semanal Dom 2:00 AM",
        "watch_protector_retry":  "🛡️ Reintentos Protector",
        "watch_hunter_verify":    "🎯 Verificación bloqueo firewall",
        "watch_docker":           "⚙️ Reinicios del container",
        "watch_connectivity":     "🌐 Conectividad del servidor",
        "watch_groq":             "⚙️ API Groq",
        "watch_security":         "🎯 Firewall Linux/OpenWrt",
        "watch_mikrotik_security":"🎯 Firewall MikroTik",
        "auto_unblock":           "🎯 Desbloqueo automático",
    }

    now    = _t.time()
    status = get_monitor_status()
    lines  = []

    for name, label in LABELS.items():
        entry = status.get(name)
        if not entry:
            lines.append(f"  ⚪ {label} — <i>sin datos aún</i>")
            continue
        if entry.get("error"):
            err = fmt.e(entry["error"][:60])
            lines.append(f"  🔴 {label}\n      <code>{err}</code>")
        else:
            last_ok = entry.get("last_ok")
            if last_ok:
                mins = int((now - last_ok) / 60)
                ago  = f"{mins}m" if mins < 60 else f"{mins//60}h{mins%60:02d}m"
            else:
                ago = "?"
            last_alert = entry.get("last_alert")
            alert_tag  = ""
            if last_alert:
                am = int((now - last_alert) / 60)
                alert_ago = f"{am}m" if am < 60 else f"{am//60}h{am%60:02d}m"
                alert_tag = f" · ⚡ alerta hace {alert_ago}"
            lines.append(f"  ✅ {label} — {fmt.e(ago)}{alert_tag}")

    await update.message.reply_text(
        fmt.card("📡", "Monitores automáticos", lines),
        parse_mode=PM
