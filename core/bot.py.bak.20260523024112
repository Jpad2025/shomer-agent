                   if n.get("ip") == ip or n.get("ip_address") == ip), None)
    nombre = (node or {}).get("name", ip)
    status = (node or {}).get("status", "desconocido")
    monitor.set_suppression(ip, nombre, duracion_min)

    await update.message.reply_text(
        fmt.card("🔧", f"Modo en sitio — {nombre}", [
            fmt.row_code("📍", "IP", ip),
            fmt.row("📶", "Estado actual", f"{fmt.status_icon(status)} {status}"),
            fmt.row("⏱️", "Supresión", f"{duracion_min} minutos"),
            "<i>Guardian sigue monitoreando. Al terminar recibirás el estado final.</i>",
