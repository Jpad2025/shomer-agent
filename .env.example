# Copiar a .env y completar con valores reales
# NUNCA subir .env a git

TELEGRAM_BOT_TOKEN=7xxxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=           # ID del chat del técnico (obtener con @userinfobot)
# 1 = despliegue cliente (Bogotá): solo herramientas de campo; la IA usa /app/docs/campo/*.md (incluidos en imagen).
#    No monta CLAUDE.md al contenedor — el técnico no recibe arquitectura interna por el modelo.
# 0 = laboratorio USB: modo developer opcional; podés montar CLAUDE/SISTEMA en /app/docs/developer/ (compose comentado).
AGENT_TECHNICIAN_ONLY=1
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Proveedor LLM para conversación interactiva del técnico ────────────────
# groq   = solo Groq (default, gratis)
# openai = GPT-4o mini para chat + Groq para monitores background
# Si OpenAI falla o supera caps → fallback automático a Groq.
LLM_PROVIDER_INTERACTIVE=groq

# OpenAI — https://platform.openai.com/api-keys
# Límite mensual en web: Settings → Limits → Monthly budget (ej. $5)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Si el lab tiene dos rutas (cable + WiFi), IP local WiFi para salir a OpenAI
# Ejemplo lab .205: 10.0.0.109 — dejar vacío si una sola ruta a internet
OPENAI_BIND_IP=

# Hard caps OpenAI en el servidor — techo ~$0.10/mes por Shomer (además del límite $5 web)
OPENAI_LIMIT_PER_MESSAGE=2000
OPENAI_LIMIT_PER_USER_DAILY=8000
OPENAI_LIMIT_DAILY=12000

# Umbrales globales (todos los proveedores) — activan modo mantenimiento
TOKEN_WARN_DAILY=80000
TOKEN_LIMIT_DAILY=120000

# URL del Shomer local (no cambiar en producción)
SHOMER_URL=http://127.0.0.1:8000
SHOMER_USER=admin
SHOMER_PASS=

# Archivo de dispositivos
DEVICES_FILE=/app/data/devices.json
